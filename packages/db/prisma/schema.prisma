generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  avatarUrl String?
  events    Event[]
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Contact {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  aliases      String[] @default([])
  email        String?
  phone        String?
  dietaryNeeds String[] @default([])
  specialNeeds String[] @default([])
  tags         String[] @default([])
  guests       Guest[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Event {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  date       DateTime
  type       EventType   @default(WEDDING)
  guests          Guest[]
  tags            Tag[]
  tables          Table[]
  edges           Edge[]
  seatingSnapshot SeatingSnapshot?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
}

enum EventType {
  WEDDING
  BANQUET
  CORPORATE
  OTHER
}

enum Side {
  GROOM
  BRIDE
  MUTUAL
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  MODIFIED
}

model Guest {
  id                String     @id @default(cuid())
  eventId           String
  event             Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contactId         String
  contact           Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  side              Side?
  relationScore     Int        @default(3)
  rsvpStatus        RsvpStatus @default(PENDING)
  attendeeCount     Int        @default(1)
  plusOneName        String?
  dietaryNeeds      String[]   @default([])
  specialNeeds      String[]   @default([])
  satisfactionScore Float      @default(50)
  isOverflow        Boolean    @default(false)
  isIsolated        Boolean    @default(false)
  formToken         String?    @unique

  assignedTableId   String?
  assignedTable     Table?           @relation(fields: [assignedTableId], references: [id])
  tags              GuestTag[]
  preferencesFrom   SeatPreference[] @relation("PreferenceFrom")
  preferencesTo     SeatPreference[] @relation("PreferenceTo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, contactId])
  @@index([eventId])
  @@index([contactId])
  @@index([formToken])
}

enum AssignedBy {
  HOST
  GUEST
}

model Tag {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  guests    GuestTag[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([eventId, name])
  @@index([eventId])
}

model GuestTag {
  guestId    String
  guest      Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedBy AssignedBy @default(HOST)
  createdAt  DateTime   @default(now())

  @@id([guestId, tagId])
  @@index([tagId])
}

model SeatPreference {
  guestId     String
  guest       Guest  @relation("PreferenceFrom", fields: [guestId], references: [id], onDelete: Cascade)
  preferredId String
  preferred   Guest  @relation("PreferenceTo", fields: [preferredId], references: [id], onDelete: Cascade)
  rank        Int    // 1, 2, 3

  @@id([guestId, preferredId])
  @@index([preferredId])
}

model Table {
  id                  String   @id @default(cuid())
  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name                String
  capacity            Int      @default(10)
  positionRow         Int      @default(0)
  positionCol         Int      @default(0)
  averageSatisfaction Float    @default(0)
  tags                String[] @default([])
  guests              Guest[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([eventId])
}

model SeatingSnapshot {
  id                  String   @id @default(cuid())
  eventId             String   @unique
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name                String
  data                Json     // [{ guestId, tableId, satisfactionScore, isOverflow }]
  averageSatisfaction Float    @default(0)
  createdAt           DateTime @default(now())
}

enum EdgeType {
  MUTUAL
  ONE_WAY
  SAME_GROUP
  INFERRED
}

model Edge {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromGuestId String
  toGuestId   String
  weight      Float    @default(1)
  type        EdgeType
  createdAt   DateTime @default(now())

  @@unique([eventId, fromGuestId, toGuestId])
  @@index([eventId])
}


