DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5432/seatern"
DIRECT_URL="postgresql://postgres:postgres@host.docker.internal:5432/seatern"

# Supabase（VITE_ 前綴讓前後端都能讀）
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# LINE Login（不加 VITE_ 前綴，僅後端使用）
LINE_CHANNEL_ID="your-line-channel-id"
LINE_CHANNEL_SECRET="your-line-channel-secret"

# Supabase Admin（service_role key，絕對不能暴露到前端）
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Google Analytics 4（前端，未設時完全不載入 gtag）
VITE_GA_MEASUREMENT_ID=""
