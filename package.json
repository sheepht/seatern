{
  "name": "seatern",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/db",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "dev": "npm run dev:api & npm run dev:web",
    "build:shared": "npm run build -w packages/shared",
    "build:db": "npm run build -w packages/db",
    "build:api": "npm run build -w packages/api",
    "build:web": "npm run build -w packages/web",
    "build": "npm run build:shared && npm run build:db && npm run build:api && npm run build:web",
    "db:generate": "npm run generate -w packages/db",
    "db:migrate": "npm run migrate -w packages/db",
    "db:push": "npm run push -w packages/db",
    "db:seed": "npm run seed -w packages/db",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
